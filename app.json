{
  "expo": {
    "name": "PDM Tarefas",
    "slug": "pdm-tarefas",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
